{
  "name": "project-tpa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "db:start": "docker compose -f docker-compose.db.yml up -d mysql",
    "db:stop": "docker compose -f docker-compose.db.yml stop mysql",
    "db:down": "docker compose -f docker-compose.db.yml down",
    "db:logs": "docker compose -f docker-compose.db.yml logs mysql --tail=120",
    "dev:client": "vite --host",
    "dev:landing": "vite --config apps/landing/vite.config.js --host --port 5174 --strictPort",
    "dev:server": "npm run dev --prefix server",
    "build": "tsc -b && vite build",
    "build:landing": "npm run images:landing && vite build --config apps/landing/vite.config.js",
    "images:landing": "npm run optimize:landing-images --prefix server",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:landing": "vite preview --config apps/landing/vite.config.js --host --port 4174 --strictPort",
    "zip:source": "powershell -ExecutionPolicy Bypass -File .\\ops\\create-source-zip.ps1",
    "runtime:start": "powershell -ExecutionPolicy Bypass -File .\\ops\\start-tpa.ps1",
    "runtime:status": "powershell -ExecutionPolicy Bypass -File .\\ops\\status-tpa.ps1",
    "runtime:restart": "powershell -ExecutionPolicy Bypass -File .\\ops\\restart-tpa.ps1",
    "runtime:prod:start": "powershell -ExecutionPolicy Bypass -File .\\ops\\start-tpa-prod.ps1",
    "runtime:prod:status": "powershell -ExecutionPolicy Bypass -File .\\ops\\status-tpa-prod.ps1",
    "runtime:prod:restart": "powershell -ExecutionPolicy Bypass -File .\\ops\\restart-tpa-prod.ps1",
    "runtime:prod:tunnel:ensure": "powershell -ExecutionPolicy Bypass -File .\\ops\\ensure-cloudflare-tunnel.ps1",
    "runtime:autostart:on": "powershell -ExecutionPolicy Bypass -File .\\ops\\install-autostart.ps1",
    "runtime:autostart:off": "powershell -ExecutionPolicy Bypass -File .\\ops\\uninstall-autostart.ps1",
    "runtime:startup:on": "powershell -ExecutionPolicy Bypass -File .\\ops\\install-startup-folder.ps1",
    "runtime:startup:off": "powershell -ExecutionPolicy Bypass -File .\\ops\\uninstall-startup-folder.ps1"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.9",
    "@mui/x-date-pickers": "^8.27.2",
    "@tailwindcss/vite": "^4.1.18",
    "dayjs": "^1.11.20",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
