# ============================================================
# Production Environment Configuration — TPA Platform
# ============================================================
# Salin file ini menjadi .env dan isi semua nilai sebelum deploy.
# JANGAN commit file .env ke repository.
# ============================================================

NODE_ENV=production
PORT=4000

# CORS — Hanya domain production, TANPA localhost
CORS_ORIGIN=https://tparumahceria.my.id

# Session lifetime (jam)
SESSION_HOURS=8

# Auth Cookie
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
# AUTH_COOKIE_DOMAIN=.tparumahceria.my.id

# Database — Wajib user non-root dengan password kuat
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=tpa_app
DB_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT_RANDOM
DB_NAME=tpa_prod
DB_CONNECTION_LIMIT=20

# Admin — Password wajib kuat minimal 12 karakter
ADMIN_NAME=Admin Utama
ADMIN_EMAIL=admin@domainanda.com
ADMIN_PASSWORD=GANTI_DENGAN_PASSWORD_SANGAT_KUAT

# Backup — Key wajib diganti dari default, minimal 16 karakter
BACKUP_ENCRYPTION_KEY=GANTI_DENGAN_KEY_UNIK_RANDOM_MINIMAL_16_CHAR

# Security
SECURITY_CSP_ENABLED=true
TRUST_PROXY=1
GLOBAL_RATE_LIMIT_WINDOW_MS=60000
GLOBAL_RATE_LIMIT_MAX=120
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX=8
LOGIN_RATE_LIMIT_BLOCK_MS=300000
