NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
SESSION_HOURS=12
AUTH_COOKIE_NAME=tpa_session
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_DOMAIN=.domainanda.com
SECURITY_CSP_ENABLED=true
TRUST_PROXY=1
GLOBAL_RATE_LIMIT_WINDOW_MS=60000
GLOBAL_RATE_LIMIT_MAX=120
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX=8
LOGIN_RATE_LIMIT_BLOCK_MS=300000
DEFAULT_BODY_LIMIT_BYTES=2097152
UPLOAD_BODY_LIMIT_BYTES=31457280
BACKUP_ENCRYPTION_KEY=ganti-dengan-kunci-random-minimal-16-karakter
ENABLE_ADMIN_BOOTSTRAP_IN_PRODUCTION=false

ADMIN_NAME=Admin
ADMIN_EMAIL=testing.admin@gmail.com
ADMIN_PASSWORD=admin12345

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=tpa_app
DB_PASSWORD=ganti-password-db-kuat
DB_NAME=tpa_platform
DB_CONNECTION_LIMIT=10
