# ===================================
# KONFIGURASI EMAIL / SMTP
# ===================================

# Opsi 1: Brevo (Gratis 300 email/hari) - REKOMENDASI
EMAIL_PROVIDER=brevo
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_FROM=noreply@tpa-rumahceria.com
EMAIL_FROM_NAME=TPA Rumah Ceria
EMAIL_USER=your-brevo-username
EMAIL_PASSWORD=your-brevo-api-key

# Opsi 2: Gmail SMTP (Google Workspace)
# EMAIL_PROVIDER=gmail
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_FROM=info@tpa-rumahceria.com
# EMAIL_FROM_NAME=TPA Rumah Ceria
# EMAIL_USER=info@tpa-rumahceria.com
# EMAIL_PASSWORD=your-app-password

# Opsi 3: SendGrid
# EMAIL_PROVIDER=sendgrid
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_FROM=noreply@tpa-rumahceria.com
# EMAIL_FROM_NAME=TPA Rumah Ceria
# EMAIL_USER=apikey
# EMAIL_PASSWORD=SG.your-sendgrid-api-key

# Opsi 4: Resend
# EMAIL_PROVIDER=resend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_FROM=noreply@tpa-rumahceria.com
# EMAIL_FROM_NAME=TPA Rumah Ceria
# EMAIL_USER=resend
# EMAIL_PASSWORD=re_your-api-key

# Pengaturan Notifikasi
EMAIL_NOTIFICATIONS_ENABLED=true
EMAIL_ON_CHILD_CHECK_IN=true
EMAIL_ON_CHILD_CHECK_OUT=true
EMAIL_ON_BILLING_DUE=true
EMAIL_ON_LOGIN_ALERT=true
