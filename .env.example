# Frontend
VITE_API_BASE_URL=/api/v1
VITE_PARENT_PORTAL_URL=http://localhost:5173/portal-orang-tua
VITE_STAFF_PORTAL_URL=http://localhost:5173/
VITE_ENFORCE_PARENT_SUBDOMAIN=false

# Runtime
NODE_ENV=development
PORT=4000
SESSION_HOURS=12
TRUST_PROXY=0
PARENT_PORTAL_ENFORCE_SUBDOMAIN=false

# Browser session cookie
AUTH_COOKIE_NAME=tpa_session
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=

# Security
SECURITY_CSP_ENABLED=true
GLOBAL_RATE_LIMIT_WINDOW_MS=60000
GLOBAL_RATE_LIMIT_MAX=120
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX=8
LOGIN_RATE_LIMIT_BLOCK_MS=300000
DEFAULT_BODY_LIMIT_BYTES=2097152
UPLOAD_BODY_LIMIT_BYTES=31457280

# Cross-origin allowlist
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Bootstrap admin
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=12345678

# Backup
BACKUP_ENCRYPTION_KEY=dev-only-backup-key-change-this

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=db_TPA
DB_CONNECTION_LIMIT=10
